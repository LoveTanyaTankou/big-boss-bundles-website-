    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap"
        rel="stylesheet"
    >

    <style>
        :root {
            --gold: #D4A622;
            --teal: #00A6D6;
            --black: #0A0A0A;
            --white: #FFFFFF;
            --cream: #F7F5F0;
            --gray: #555555;
            --border: #E6E1D7;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: var(--white);
            color: var(--black);
            font-family: "DM Sans", Arial, sans-serif;
            line-height: 1.7;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .announcement {
            padding: 11px 20px;
            background: var(--teal);
            color: var(--white);
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-align: center;
            text-transform: uppercase;
        }

        .header {
            background: var(--black);
            color: var(--white);
        }

        .brand-row {
            padding: 27px 20px 20px;
            text-align: center;
        }

        .brand-name {
            display: block;
            color: var(--gold);
            font-family: "Playfair Display", Georgia, serif;
            font-size: clamp(1.8rem, 4vw, 3rem);
            font-weight: 700;
            letter-spacing: 0.04em;
            line-height: 1;
        }

        .brand-tagline {
            display: block;
            margin-top: 8px;
            color: var(--teal);
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.16em;
            text-transform: uppercase;
        }

        .navigation {
            display: flex;
            justify-content: center;
            gap: 25px;
            padding: 15px 20px;
            overflow-x: auto;
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            white-space: nowrap;
        }

        .navigation a {
            font-size: 0.73rem;
            font-weight: 700;
            letter-spacing: 0.07em;
            text-transform: uppercase;
        }

        .navigation a:hover {
            color: var(--gold);
        }

        .page-hero {
            padding: 85px 7%;
            background:
                linear-gradient(
                    135deg,
                    rgba(212, 166, 34, 0.14),
                    transparent 55%
                ),
                var(--cream);
            text-align: center;
        }

        .eyebrow {
            margin-bottom: 12px;
            color: var(--teal);
            font-size: 0.74rem;
            font-weight: 800;
            letter-spacing: 0.19em;
            text-transform: uppercase;
        }

        .page-hero h1 {
            font-family: "Playfair Display", Georgia, serif;
            font-size: clamp(2.7rem, 6vw, 5rem);
            line-height: 1.05;
        }

        .page-hero p {
            max-width: 760px;
            margin: 20px auto 0;
            color: var(--gray);
        }

        .faq-layout {
            display: grid;
            max-width: 1200px;
            margin: 0 auto;
            padding: 75px 6%;
            grid-template-columns: 260px minmax(0, 1fr);
            gap: 55px;
        }

        .faq-menu {
            position: sticky;
            top: 25px;
            height: fit-content;
            padding: 24px;
            background: var(--black);
            color: var(--white);
        }

        .faq-menu h2 {
            margin-bottom: 15px;
            color: var(--gold);
            font-family: "Playfair Display", Georgia, serif;
            font-size: 1.3rem;
        }

        .faq-menu a {
            display: block;
            padding: 9px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.11);
            color: rgba(255, 255, 255, 0.78);
            font-size: 0.84rem;
        }

        .faq-menu a:hover {
            color: var(--teal);
        }

        .faq-section {
            margin-bottom: 55px;
            scroll-margin-top: 25px;
        }

        .faq-section h2 {
            margin-bottom: 22px;
            color: var(--black);
            font-family: "Playfair Display", Georgia, serif;
            font-size: 2rem;
        }

        details {
            margin-bottom: 14px;
            border: 1px solid var(--border);
            background: var(--cream);
        }

        summary {
            position: relative;
            padding: 22px 58px 22px 24px;
            cursor: pointer;
            font-weight: 700;
            list-style: none;
        }

        summary::-webkit-details-marker {
            display: none;
        }

        summary::after {
            content: "+";
            position: absolute;
            right: 24px;
            top: 16px;
            color: var(--teal);
            font-size: 1.7rem;
            font-weight: 400;
        }

        details[open] summary::after {
            content: "−";
        }

        details p,
        details ul {
            margin: 0 24px 22px;
            color: var(--gray);
        }

        details ul {
            padding-left: 20px;
        }

        details li {
            margin-bottom: 7px;
        }

        .contact-box {
            padding: 32px;
            background: var(--black);
            color: var(--white);
            border-left: 5px solid var(--teal);
        }

        .contact-box h2 {
            margin-bottom: 12px;
            color: var(--gold);
            font-family: "Playfair Display", Georgia, serif;
            font-size: 1.8rem;
        }

        .contact-box p,
        .contact-box a {
            display: block;
            margin-bottom: 8px;
            color: rgba(255, 255, 255, 0.82);
        }

        .contact-box a:hover {
            color: var(--teal);
        }

        .footer {
            padding: 60px 6% 25px;
            background: var(--black);
            color: var(--white);
        }

        .footer-grid {
            display: grid;
            max-width: 1250px;
            margin: 0 auto;
            grid-template-columns: 1.3fr 1fr 1fr 1.3fr;
            gap: 40px;
        }

        .footer h3 {
            margin-bottom: 12px;
            color: var(--gold);
            font-family: "Playfair Display", Georgia, serif;
            font-size: 1.65rem;
        }

        .footer h4 {
            margin-bottom: 14px;
            color: var(--teal);
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }

        .footer p,
        .footer a {
            display: block;
            margin-bottom: 8px;
            color: rgba(255, 255, 255, 0.73);
            font-size: 0.86rem;
        }

        .footer a:hover {
            color: var(--gold);
        }

        .copyright {
            max-width: 1250px;
            margin: 40px auto 0;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.14);
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.75rem;
            text-align: center;
        }

        @media (max-width: 850px) {
            .faq-layout {
                grid-template-columns: 1fr;
            }

            .faq-menu {
                position: static;
            }

            .footer-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 600px) {
            .navigation {
                justify-content: flex-start;
            }

            .page-hero {
                padding: 65px 7%;
            }

            .faq-layout {
                padding: 55px 6%;
            }

            .footer-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>


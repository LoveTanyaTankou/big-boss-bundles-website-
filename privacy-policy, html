    <style>
        :root {
            --gold: #D4A622;
            --teal: #00A6D6;
            --black: #0A0A0A;
            --white: #FFFFFF;
            --cream: #F8F6F0;
            --gray: #606060;
            --border: #E8E2D3;
            --shadow: 0 18px 45px rgba(0, 0, 0, 0.10);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: var(--white);
            color: var(--black);
            font-family: "DM Sans", Arial, sans-serif;
            line-height: 1.75;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .announcement {
            padding: 11px 20px;
            background: var(--teal);
            color: var(--white);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.14em;
            text-align: center;
            text-transform: uppercase;
        }

        .announcement span {
            padding: 0 10px;
            color: var(--gold);
        }

        .header {
            background: var(--black);
            border-bottom: 4px solid var(--gold);
        }

        .brand-row {
            display: flex;
            max-width: 1400px;
            margin: 0 auto;
            align-items: center;
            justify-content: space-between;
            padding: 24px 5%;
        }

        .brand {
            display: flex;
            flex-direction: column;
        }

        .brand-name {
            color: var(--gold);
            font-family: "Playfair Display", Georgia, serif;
            font-size: clamp(1.55rem, 3vw, 2.5rem);
            font-weight: 700;
            letter-spacing: 0.035em;
            line-height: 1;
        }

        .brand-tagline {
            margin-top: 7px;
            color: var(--teal);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.13em;
            text-transform: uppercase;
        }

        .home-button {
            padding: 11px 17px;
            border: 2px solid var(--teal);
            color: var(--white);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.09em;
            text-transform: uppercase;
            transition: 0.2s ease;
        }

        .home-button:hover {
            background: var(--teal);
        }

        .navigation {
            display: flex;
            justify-content: center;
            gap: 25px;
            padding: 15px 20px;
            overflow-x: auto;
            background: var(--white);
            white-space: nowrap;
        }

        .navigation a {
            color: var(--black);
            font-size: 0.73rem;
            font-weight: 800;
            letter-spacing: 0.07em;
            text-transform: uppercase;
        }

        .navigation a:hover,
        .navigation .active {
            color: var(--teal);
        }

        .hero {
            position: relative;
            overflow: hidden;
            padding: 95px 6%;
            background:
                radial-gradient(
                    circle at 85% 15%,
                    rgba(0, 166, 214, 0.23),
                    transparent 31%
                ),
                radial-gradient(
                    circle at 10% 75%,
                    rgba(212, 166, 34, 0.25),
                    transparent 34%
                ),
                var(--black);
            color: var(--white);
            text-align: center;
        }

        .hero::before {
            content: "BB";
            position: absolute;
            top: 50%;
            left: 50%;
            color: rgba(255, 255, 255, 0.035);
            font-family: "Playfair Display", Georgia, serif;
            font-size: 19rem;
            font-weight: 700;
            line-height: 1;
            transform: translate(-50%, -50%);
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 900px;
            margin: 0 auto;
        }

        .eyebrow {
            margin-bottom: 13px;
            color: var(--teal);
            font-size: 0.75rem;
            font-weight: 900;
            letter-spacing: 0.22em;
            text-transform: uppercase;
        }

        .hero h1 {
            color: var(--gold);
            font-family: "Playfair Display", Georgia, serif;
            font-size: clamp(2.9rem, 6vw, 5.7rem);
            line-height: 1.05;
        }

        .hero p {
            max-width: 670px;
            margin: 22px auto 0;
            color: rgba(255, 255, 255, 0.81);
            font-size: 1.02rem;
        }

        .effective-date {
            display: inline-block;
            margin-top: 28px;
            padding: 9px 15px;
            border: 1px solid rgba(255, 255, 255, 0.28);
            color: var(--white);
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .page-layout {
            display: grid;
            max-width: 1300px;
            margin: 0 auto;
            grid-template-columns: 280px minmax(0, 1fr);
            gap: 50px;
            padding: 80px 5%;
        }

        .policy-menu {
            position: sticky;
            top: 25px;
            height: fit-content;
            padding: 27px;
            background: var(--cream);
            border-top: 5px solid var(--gold);
            box-shadow: var(--shadow);
        }

        .policy-menu h2 {
            margin-bottom: 17px;
            color: var(--black);
            font-family: "Playfair Display", Georgia, serif;
            font-size: 1.35rem;
        }

        .policy-menu a {
            display: block;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            color: var(--gray);
            font-size: 0.84rem;
            font-weight: 700;
        }

        .policy-menu a:hover {
            color: var(--teal);
        }

        .policy-content {
            min-width: 0;
        }

        .intro-box {
            margin-bottom: 34px;
            padding: 27px;
            border-left: 5px solid var(--teal);
            background: rgba(0, 166, 214, 0.08);
        }

        .intro-box p {
            color: #424242;
        }

        .policy-section {
            margin-bottom: 28px;
            padding: 32px;
            background: var(--white);
            border: 1px solid var(--border);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.055);
        }

        .policy-section h2 {
            margin-bottom: 15px;
            color: var(--black);
            font-family: "Playfair Display", Georgia, serif;
            font-size: clamp(1.55rem, 3vw, 2.1rem);
            line-height: 1.2;
        }

        .policy-section h2::after {
            content: "";
            display: block;
            width: 58px;
            height: 4px;
            margin-top: 11px;
            background: linear-gradient(
                90deg,
                var(--gold),
                var(--teal)
            );
        }

        .policy-section h3 {
            margin: 22px 0 8px;
            color: var(--teal);
            font-size: 1.03rem;
        }

        .policy-section p {
            margin-bottom: 13px;
            color: var(--gray);
        }

        .policy-section p:last-child {
            margin-bottom: 0;
        }

        .policy-section ul {
            margin: 12px 0 15px 22px;
            color: var(--gray);
        }

        .policy-section li {
            margin-bottom: 8px;
            padding-left: 4px;
        }

        .policy-section strong {
            color: var(--black);
        }

        .contact-card {
            padding: 36px;
            background:
                linear-gradient(
                    135deg,
                    rgba(0, 166, 214, 0.19),
                    transparent 58%
                ),
                var(--black);
            color: var(--white);
            border-bottom: 5px solid var(--gold);
        }

        .contact-card h2 {
            margin-bottom: 15px;
            color: var(--gold);
            font-family: "Playfair Display", Georgia, serif;
            font-size: 2rem;
        }

        .contact-card p,
        .contact-card a {
            color: rgba(255, 255, 255, 0.82);
        }

        .contact-card a:hover {
            color: var(--teal);
        }

        .policy-links {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 5% 75px;
        }

        .policy-links a {
            display: flex;
            min-height: 80px;
            align-items: center;
            justify-content: center;
            padding: 18px;
            border: 2px solid var(--teal);
            background: var(--white);
            color: var(--black);
            font-size: 0.76rem;
            font-weight: 900;
            letter-spacing: 0.07em;
            text-align: center;
            text-transform: uppercase;
            transition: 0.2s ease;
        }

        .policy-links a:hover {
            background: var(--teal);
            color: var(--white);
            transform: translateY(-3px);
        }

        .footer {
            padding: 64px 6% 24px;
            background: var(--black);
            color: var(--white);
        }

        .footer-grid {
            display: grid;
            max-width: 1350px;
            margin: 0 auto;
            grid-template-columns: 1.3fr 1fr 1fr 1.3fr;
            gap: 42px;
        }

        .footer h3 {
            margin-bottom: 13px;
            color: var(--gold);
            font-family: "Playfair Display", Georgia, serif;
            font-size: 1.75rem;
        }

        .footer h4 {
            margin-bottom: 14px;
            color: var(--teal);
            font-size: 0.75rem;
            letter-spacing: 0.13em;
            text-transform: uppercase;
        }

        .footer p,
        .footer a {
            display: block;
            margin-bottom: 9px;
            color: rgba(255, 255, 255, 0.72);
            font-size: 0.86rem;
        }

        .footer a:hover {
            color: var(--gold);
        }

        .footer-bottom {
            max-width: 1350px;
            margin: 42px auto 0;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            color: rgba(255, 255, 255, 0.48);
            font-size: 0.77rem;
            text-align: center;
        }

        @media (max-width: 950px) {
            .page-layout {
                grid-template-columns: 1fr;
            }

            .policy-menu {
                position: static;
            }

            .policy-menu nav {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 0 20px;
            }

            .footer-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .policy-links {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 650px) {
            .brand-row {
                justify-content: center;
                text-align: center;
            }

            .home-button {
                display: none;
            }

            .navigation {
                justify-content: flex-start;
            }

            .hero {
                padding: 72px 6%;
            }

            .hero::before {
                font-size: 11rem;
            }

            .page-layout {
                padding: 55px 5%;
            }

            .policy-menu nav,
            .footer-grid,
            .policy-links {
                grid-template-columns: 1fr;
            }

            .policy-section {
                padding: 25px 21px;
            }
        }
    </style>
</head>

